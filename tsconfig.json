{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "#/*" : ["./src/*"],
      "#database": ["./src/libs/database.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.map", "node_modules", "dist"]
}